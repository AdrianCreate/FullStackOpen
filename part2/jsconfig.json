{
    "compilerOptions": {
        "checkJs": true,

        "strict": false,
        "noImplicitAny": false,
        "noImplicitThis": false,
        "strictNullChecks": false,

        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ES2022",
        "jsx": "react-jsx",

        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"]
        },

        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "exclude": ["node_modules", "dist", "build", ".next"]
}
